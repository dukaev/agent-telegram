{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "agent-telegram-site",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "agent-telegram.com",
      "custom_domain": true
    }
  ]
}
